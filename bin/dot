#!/usr/bin/env bash
# dot - dotfiles manager using GNU Stow + fzf
set -euo pipefail

DOTFILES="${DOTFILES_DIR:-$HOME/dotfiles}"

die()  { echo "error: $*" >&2; exit 1; }
info() { echo "  $*"; }

_is_managed() { [[ -d "$DOTFILES/$1" ]]; }

_stow()   { (cd "$DOTFILES" && stow --target="$HOME" --restow "$1"); }
_unstow() { (cd "$DOTFILES" && stow --target="$HOME" -D "$1"); }

# Stow a package, auto-removing any conflicting files/dirs first.
_stow_force() {
  local pkg="$1" output attempt=0 conflicts conflict_path

  while (( ++attempt <= 20 )); do
    output=$(cd "$DOTFILES" && stow --target="$HOME" --restow --simulate "$pkg" 2>&1) && {
      (cd "$DOTFILES" && stow --target="$HOME" --restow "$pkg")
      return 0
    }

    conflicts=()
    while IFS= read -r line; do
      if [[ "$line" =~ \*\ existing\ target\ is.*:[[:space:]](.+)$ ]]; then
        conflicts+=("${BASH_REMATCH[1]}")
      fi
    done <<< "$output"

    if [[ ${#conflicts[@]} -eq 0 ]]; then
      echo "$output" >&2
      die "stow failed for '$pkg' (unexpected error)"
    fi

    for conflict_path in "${conflicts[@]}"; do
      info "removing conflict: ~/$conflict_path"
      rm -rf "$HOME/$conflict_path"
    done
  done

  die "could not resolve conflicts for '$pkg' after 20 attempts"
}

# ── add ─────────────────────────────────────────────────────────────────────

_add_one() {
  # Input is a path relative to $HOME, e.g.:
  #   .config/nvim   → ~/.config/nvim
  #   .bashrc        → ~/.bashrc
  #   whatever       → ~/whatever
  local input="$1"
  local src="$HOME/$input"

  [[ -e "$src" ]] || die "Not found: ~/$input"

  local pkg dest_parent
  if [[ "$input" == .config/* ]]; then
    pkg="${input#.config/}"
    dest_parent="$DOTFILES/$pkg/.config"
  else
    pkg="${input#.}"   # .bashrc → bashrc, .gitconfig → gitconfig
    dest_parent="$DOTFILES/$pkg"
  fi

  _is_managed "$pkg" && die "'$pkg' is already managed (~/dotfiles/$pkg exists)"

  mkdir -p "$dest_parent"
  mv "$src" "$dest_parent/"
  _stow "$pkg"
  info "added '$pkg'  →  ~/$input"
}

cmd_add() {
  if [[ $# -gt 0 ]]; then
    _add_one "$1"
    return
  fi

  # Interactive mode — build candidate list
  local candidates=()

  while IFS= read -r dir; do
    local name; name=$(basename "$dir")
    _is_managed "$name" || candidates+=(".config/$name")
  done < <(find "$HOME/.config" -maxdepth 1 -mindepth 1 -type d | sort)

  for f in .bashrc .bash_profile .bash_logout .zshrc .zprofile .profile \
            .gitconfig .vimrc .tmux.conf .inputrc .xinitrc .xprofile .Xresources; do
    if [[ -f "$HOME/$f" ]]; then
      local pkg="${f#.}"
      _is_managed "$pkg" || candidates+=("$f")
    fi
  done

  if [[ ${#candidates[@]} -eq 0 ]]; then echo "Nothing new to add."; return; fi

  local selected
  selected=$(
    printf "%s\n" "${candidates[@]}" |
    fzf --multi \
        --prompt "Add to dotfiles > " \
        --header "TAB = multi-select   ENTER = confirm   ESC = cancel" \
        --preview '
          item={}
          if [[ "$item" == .config/* ]]; then
            ls -1 --color=always "$HOME/${item}" 2>/dev/null
          else
            file "$HOME/$item"; echo; cat "$HOME/$item" 2>/dev/null | head -30
          fi
        ' \
        --preview-window=right:40%
  ) || return 0   # ESC / Ctrl-C exits cleanly

  local name
  while IFS= read -r name; do
    [[ -z "$name" ]] && continue
    _add_one "$name"
  done <<< "$selected"
}

# ── remove ───────────────────────────────────────────────────────────────────

cmd_remove() {
  local pkg="${1:-}"
  [[ -z "$pkg" ]] && die "Usage: dot remove <package>"
  [[ -d "$DOTFILES/$pkg" ]] || die "Package '$pkg' not found"

  _unstow "$pkg"

  # Restore .config items
  if [[ -d "$DOTFILES/$pkg/.config" ]]; then
    for item in "$DOTFILES/$pkg/.config"/*/; do
      [[ -e "$item" ]] || continue
      mv "$item" "$HOME/.config/"
    done
  fi
  # Restore home dotfiles (skip the .config pass-through dir)
  for item in "$DOTFILES/$pkg"/.[!.]*  "$DOTFILES/$pkg"/[!.]*; do
    [[ -e "$item" ]] || continue
    [[ "$(basename "$item")" == ".config" ]] && continue
    mv "$item" "$HOME/"
  done

  rm -rf "$DOTFILES/$pkg"
  info "removed '$pkg', files restored"
}

# ── restore ──────────────────────────────────────────────────────────────────

cmd_restore() {
  local target_pkg="${1:-}" packages=()

  if [[ -n "$target_pkg" ]]; then
    [[ -d "$DOTFILES/$target_pkg" ]] || die "Package '$target_pkg' not found"
    packages=("$target_pkg")
  else
    for pkg in "$DOTFILES"/*/; do
      [[ -d "$pkg" ]] || continue
      packages+=("$(basename "$pkg")")
    done
  fi

  if [[ ${#packages[@]} -eq 0 ]]; then echo "No packages found in $DOTFILES."; return; fi

  for pkg in "${packages[@]}"; do
    info "restoring '$pkg'..."
    _stow_force "$pkg"
  done
  info "done"
}

# ── list ─────────────────────────────────────────────────────────────────────

cmd_list() {
  echo "Managed packages in $DOTFILES:"
  local count=0
  for pkg in "$DOTFILES"/*/; do
    [[ -d "$pkg" ]] || continue
    local name; name=$(basename "$pkg")

    # Check link status by examining expected stow symlink targets
    local status="not linked"
    if [[ -d "$DOTFILES/$name/.config" ]]; then
      # .config-style package: stow creates ~/.config/<subdir> symlinks
      for subdir in "$DOTFILES/$name/.config"/*/; do
        [[ -d "$subdir" ]] || continue
        local subname; subname=$(basename "$subdir")
        local link="$HOME/.config/$subname"
        if [[ -L "$link" ]]; then
          status="linked"; break
        fi
      done
    else
      # Flat package: stow creates ~/item symlinks for each top-level item
      for item in "$DOTFILES/$name"/* "$DOTFILES/$name"/.[!.]*; do
        [[ -e "$item" ]] || continue
        local iname; iname=$(basename "$item")
        local link="$HOME/$iname"
        if [[ -L "$link" ]]; then
          status="linked"; break
        fi
      done
    fi

    local dest
    if [[ -d "$pkg/.config" ]]; then
      dest="~/.config/$name"
    else
      dest="~/$(ls -1 "$pkg" 2>/dev/null | head -1)"
    fi

    printf "  %-20s → %-35s [%s]\n" "$name" "$dest" "$status"
    count=$(( count + 1 ))
  done
  if [[ $count -eq 0 ]]; then echo "  (none yet — run 'dot add' to get started)"; fi
}

# ── links ────────────────────────────────────────────────────────────────────

cmd_links() {
  echo "Active symlinks → $DOTFILES:"
  local count=0
  while IFS= read -r link; do
    local real; real=$(readlink -f "$link" 2>/dev/null) || continue
    [[ "$real" == "$DOTFILES/"* ]] || continue
    local rel_link="${link#$HOME/}"
    local pkg; pkg=$(echo "$real" | sed "s|^$DOTFILES/||" | cut -d'/' -f1)
    printf "  ~/%-45s [%s]\n" "$rel_link" "$pkg"
    count=$(( count + 1 ))
  done < <(find "$HOME" -maxdepth 5 -type l 2>/dev/null | sort)
  if [[ $count -eq 0 ]]; then echo "  (no active symlinks found pointing to $DOTFILES)"; fi
}

# ── sync ─────────────────────────────────────────────────────────────────────

cmd_sync() {
  local msg="${1:-sync dotfiles $(date +%Y-%m-%d)}"
  cd "$DOTFILES"
  git add -A
  if git diff --cached --quiet; then
    echo "Nothing to commit."
  else
    git commit -m "$msg"
  fi
  git push
}

# ── save ─────────────────────────────────────────────────────────────────────
# Commit everything and push — overwrites remote with local state.

cmd_save() {
  local msg="${1:-sync dotfiles $(date +%Y-%m-%d)}"
  cd "$DOTFILES"
  git add -A
  if git diff --cached --quiet; then
    info "nothing to commit, pushing anyway..."
  else
    git commit -m "$msg"
  fi
  git push --force
  info "saved"
}

# ── load ─────────────────────────────────────────────────────────────────────
# Force pull from remote and restow all packages — overwrites local state.

cmd_load() {
  cd "$DOTFILES"
  git fetch origin
  git reset --hard origin/master
  info "pulled latest from remote"
  cmd_restore
}

# ── help / dispatch ──────────────────────────────────────────────────────────

usage() {
  cat <<EOF
dot — dotfiles manager (GNU Stow + fzf)

  dot add [name]      Add a ~/.config dir or dotfile (interactive if no arg)
  dot remove <pkg>    Unstow a package and restore files to original location
  dot restore [pkg]   Re-stow all packages (or one), removing conflicting files
  dot list            Show managed packages and their link status
  dot links           Show all active symlinks pointing to dotfiles
  dot sync [msg]      git commit -a and push
  dot save [msg]      commit + force push (overwrites remote)
  dot load            force pull + restow all (overwrites local)
  dot status          git status in the dotfiles repo
  dot edit            Open dotfiles dir in \$EDITOR
EOF
}

cmd="${1:-help}"; shift || true
case "$cmd" in
  add)     cmd_add "$@" ;;
  remove)  cmd_remove "$@" ;;
  restore) cmd_restore "$@" ;;
  list)    cmd_list ;;
  links)   cmd_links ;;
  sync)    cmd_sync "$@" ;;
  save)    cmd_save "$@" ;;
  load)    cmd_load ;;
  status)  (cd "$DOTFILES" && git status) ;;
  edit)    "${EDITOR:-vim}" "$DOTFILES" ;;
  help|-h|--help) usage ;;
  *) die "Unknown command '$cmd'. Run 'dot help'." ;;
esac
